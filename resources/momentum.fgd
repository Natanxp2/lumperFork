	progress_number(integer) : "Progress Number" : 0 : "The progress value of this trigger. If the player touches a trigger_momentum_progress with a Progress Number that is lower than the last one they activated, it will be ignored. A trigger with a Progress Number of 0 will always activate."
	]

@SolidClass base(Trigger) 
