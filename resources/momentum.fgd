	disableflashlight(boolean) : "Disable clustered lights" : 0 : "Used to disable clustered lighting and shadows on this entity."
	linedivider_visbrush(string) readonly : "----------------------------------------------------------------------------------------------------------" : : "Oops, you must\'ve misclicked."

	// Inputs
